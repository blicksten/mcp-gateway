{
  "$comment": "Cross-language parity fixtures for the SAP server-name grammar. Consumed by both internal/sapname/grammar_gen_test.go and vscode/mcp-gateway-dashboard/src/test/sap-name-grammar.gen.test.ts. Regenerate parsers via `go run ./tools/grammar-gen`. Add new cases at the end — both tests pick them up automatically.",
  "$schema": "informal",
  "version": 1,
  "cases": [
    { "name": "vsp-DEV",          "expected": { "kind": "vsp",     "sid": "DEV", "client": "" } },
    { "name": "vsp-DEV-100",      "expected": { "kind": "vsp",     "sid": "DEV", "client": "100" } },
    { "name": "vsp-ABC",          "expected": { "kind": "vsp",     "sid": "ABC", "client": "" } },
    { "name": "vsp-ABC-200",      "expected": { "kind": "vsp",     "sid": "ABC", "client": "200" } },
    { "name": "vsp-S4D",          "expected": { "kind": "vsp",     "sid": "S4D", "client": "" } },
    { "name": "vsp-S4D-800",      "expected": { "kind": "vsp",     "sid": "S4D", "client": "800" } },
    { "name": "vsp-PRD",          "expected": { "kind": "vsp",     "sid": "PRD", "client": "" } },
    { "name": "vsp-PRD-001",      "expected": { "kind": "vsp",     "sid": "PRD", "client": "001" } },
    { "name": "vsp-Q01",          "expected": { "kind": "vsp",     "sid": "Q01", "client": "" } },
    { "name": "vsp-Q01-066",      "expected": { "kind": "vsp",     "sid": "Q01", "client": "066" } },
    { "name": "vsp-D01",          "expected": { "kind": "vsp",     "sid": "D01", "client": "" } },
    { "name": "vsp-XYZ-999",      "expected": { "kind": "vsp",     "sid": "XYZ", "client": "999" } },

    { "name": "sap-gui-DEV",      "expected": { "kind": "sap-gui", "sid": "DEV", "client": "" } },
    { "name": "sap-gui-DEV-100",  "expected": { "kind": "sap-gui", "sid": "DEV", "client": "100" } },
    { "name": "sap-gui-ABC",      "expected": { "kind": "sap-gui", "sid": "ABC", "client": "" } },
    { "name": "sap-gui-ABC-200",  "expected": { "kind": "sap-gui", "sid": "ABC", "client": "200" } },
    { "name": "sap-gui-S23",      "expected": { "kind": "sap-gui", "sid": "S23", "client": "" } },
    { "name": "sap-gui-S23-800",  "expected": { "kind": "sap-gui", "sid": "S23", "client": "800" } },
    { "name": "sap-gui-QAS",      "expected": { "kind": "sap-gui", "sid": "QAS", "client": "" } },
    { "name": "sap-gui-QAS-001",  "expected": { "kind": "sap-gui", "sid": "QAS", "client": "001" } },
    { "name": "sap-gui-S4D-800",  "expected": { "kind": "sap-gui", "sid": "S4D", "client": "800" } },
    { "name": "sap-gui-X00-000",  "expected": { "kind": "sap-gui", "sid": "X00", "client": "000" } },
    { "name": "sap-gui-Z99-999",  "expected": { "kind": "sap-gui", "sid": "Z99", "client": "999" } },

    { "name": "",                 "expected": null, "$reason": "empty string" },
    { "name": "vsp",              "expected": null, "$reason": "prefix only, no separator yet" },
    { "name": "vsp-",             "expected": null, "$reason": "prefix complete but no SID" },
    { "name": "vsp-DE",           "expected": null, "$reason": "SID too short (2 chars)" },
    { "name": "vsp-DEVX",         "expected": null, "$reason": "SID too long (4 chars)" },
    { "name": "vsp-dev",          "expected": null, "$reason": "lowercase SID rejected" },
    { "name": "vsp-De1",          "expected": null, "$reason": "mixed-case SID rejected" },
    { "name": "vsp-DEV-1",        "expected": null, "$reason": "client too short (1 digit)" },
    { "name": "vsp-DEV-10",       "expected": null, "$reason": "client too short (2 digits)" },
    { "name": "vsp-DEV-1234",     "expected": null, "$reason": "client too long (4 digits)" },
    { "name": "vsp-DEV-10A",      "expected": null, "$reason": "client must be all digits" },
    { "name": "vsp-DEV_100",      "expected": null, "$reason": "wrong separator (underscore)" },
    { "name": "vsp-DEV.100",      "expected": null, "$reason": "wrong separator (dot)" },

    { "name": "sap-gui",          "expected": null, "$reason": "prefix only" },
    { "name": "sap-gui-",         "expected": null, "$reason": "prefix complete, no SID" },
    { "name": "sap-gui-DE",       "expected": null, "$reason": "SID too short" },
    { "name": "sap-gui-DEVX",     "expected": null, "$reason": "SID too long" },
    { "name": "sap-gui-dev",      "expected": null, "$reason": "lowercase SID rejected" },
    { "name": "sap-gui-DEV-",     "expected": null, "$reason": "trailing separator with empty client" },
    { "name": "sap-gui-DEV-99",   "expected": null, "$reason": "client too short" },

    { "name": "my-server",        "expected": null, "$reason": "non-SAP server name" },
    { "name": "VSP-DEV",          "expected": null, "$reason": "uppercase prefix rejected (prefixes are case-sensitive)" },
    { "name": "Vsp-DEV",          "expected": null, "$reason": "title-case prefix rejected" },
    { "name": "sap-DEV",          "expected": null, "$reason": "abbreviated 'sap-' is not a valid prefix" },
    { "name": "vsp-DEV-100-extra", "expected": null, "$reason": "trailing data after valid match" },
    { "name": " vsp-DEV",         "expected": null, "$reason": "leading whitespace rejected" },
    { "name": "vsp-DEV ",         "expected": null, "$reason": "trailing whitespace rejected" }
  ]
}
