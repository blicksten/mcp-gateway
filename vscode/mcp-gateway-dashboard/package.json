{
  "name": "mcp-gateway-dashboard",
  "displayName": "MCP Gateway Dashboard",
  "description": "Manage MCP backend servers from VS Code — tree view, status bar, daemon lifecycle",
  "version": "1.22.0",
  "publisher": "mcp-gateway",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blicksten/mcp-gateway"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcp-gateway",
          "title": "MCP Gateway",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mcp-gateway": [
        {
          "id": "mcpGatewayDaemon",
          "name": "Gateway"
        },
        {
          "id": "mcpBackends",
          "name": "Backends"
        },
        {
          "id": "mcpSapSystems",
          "name": "SAP Systems",
          "when": "mcpGateway.sapSystemsEnabled"
        }
      ]
    },
    "commands": [
      {
        "command": "mcpGateway.refresh",
        "title": "MCP Gateway: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mcpGateway.showClaudeCodeIntegration",
        "title": "MCP Gateway: Show Claude Code Integration",
        "icon": "$(plug)"
      },
      {
        "command": "mcpGateway.addServer",
        "title": "MCP Gateway: Add Server",
        "icon": "$(add)"
      },
      {
        "command": "mcpGateway.importKeepassCredentials",
        "title": "MCP Gateway: Import KeePass Credentials",
        "icon": "$(key)"
      },
      {
        "command": "mcpGateway.removeServer",
        "title": "MCP Gateway: Remove Server"
      },
      {
        "command": "mcpGateway.startServer",
        "title": "MCP Gateway: Enable Server",
        "icon": "$(play)"
      },
      {
        "command": "mcpGateway.stopServer",
        "title": "MCP Gateway: Disable Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mcpGateway.restartServer",
        "title": "MCP Gateway: Restart Server",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mcpGateway.resetCircuit",
        "title": "MCP Gateway: Reset Circuit Breaker"
      },
      {
        "command": "mcpGateway.showLogs",
        "title": "MCP Gateway: Show Logs"
      },
      {
        "command": "mcpGateway.startDaemon",
        "title": "MCP Gateway: Start Daemon",
        "icon": "$(play)"
      },
      {
        "command": "mcpGateway.stopDaemon",
        "title": "MCP Gateway: Stop Daemon",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mcpGateway.restartDaemon",
        "title": "MCP Gateway: Restart Daemon",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mcpGateway.restartSapVsp",
        "title": "MCP Gateway: Restart SAP VSP"
      },
      {
        "command": "mcpGateway.restartSapGui",
        "title": "MCP Gateway: Restart SAP GUI"
      },
      {
        "command": "mcpGateway.showSapVspLogs",
        "title": "MCP Gateway: Show SAP VSP Logs"
      },
      {
        "command": "mcpGateway.showSapGuiLogs",
        "title": "MCP Gateway: Show SAP GUI Logs"
      },
      {
        "command": "mcpGateway.showServerDetail",
        "title": "MCP Gateway: Show Server Details"
      },
      {
        "command": "mcpGateway.showSapDetail",
        "title": "MCP Gateway: Show SAP System Details"
      },
      {
        "command": "mcpGateway.addSapSystem",
        "title": "MCP Gateway: Add SAP System",
        "icon": "$(add)"
      },
      {
        "command": "mcpGateway.openSettings",
        "title": "MCP Gateway: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "mcpGateway.cleanupClaudeConfig",
        "title": "MCP Gateway: Cleanup Claude Code Config (remove managed entries)"
      },
      {
        "command": "mcpGateway.previewClaudeConfigSync",
        "title": "MCP Gateway: Preview Claude Code Config Sync (dry-run)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mcpGateway.refresh",
          "when": "view == mcpGatewayDaemon",
          "group": "navigation@10"
        },
        {
          "command": "mcpGateway.showClaudeCodeIntegration",
          "when": "view == mcpGatewayDaemon",
          "group": "navigation@50"
        },
        {
          "command": "mcpGateway.openSettings",
          "when": "view == mcpGatewayDaemon",
          "group": "navigation@90"
        },
        {
          "command": "mcpGateway.refresh",
          "when": "view == mcpBackends",
          "group": "navigation@10"
        },
        {
          "command": "mcpGateway.addServer",
          "when": "view == mcpBackends",
          "group": "navigation@20"
        },
        {
          "command": "mcpGateway.showClaudeCodeIntegration",
          "when": "view == mcpBackends",
          "group": "navigation@50"
        },
        {
          "command": "mcpGateway.openSettings",
          "when": "view == mcpBackends",
          "group": "navigation@90"
        },
        {
          "command": "mcpGateway.addSapSystem",
          "when": "view == mcpSapSystems",
          "group": "navigation@20"
        },
        {
          "command": "mcpGateway.showClaudeCodeIntegration",
          "when": "view == mcpSapSystems",
          "group": "navigation@50"
        },
        {
          "command": "mcpGateway.openSettings",
          "when": "view == mcpSapSystems",
          "group": "navigation@90"
        }
      ],
      "view/item/context": [
        {
          "command": "mcpGateway.startDaemon",
          "when": "view == mcpGatewayDaemon && viewItem == gateway-unreachable",
          "group": "inline@1"
        },
        {
          "command": "mcpGateway.stopDaemon",
          "when": "view == mcpGatewayDaemon && viewItem == gateway-running",
          "group": "inline@1"
        },
        {
          "command": "mcpGateway.restartDaemon",
          "when": "view == mcpGatewayDaemon && viewItem == gateway-running",
          "group": "inline@2"
        },
        {
          "command": "mcpGateway.startServer",
          "when": "view == mcpBackends && viewItem == disabled",
          "group": "1_lifecycle"
        },
        {
          "command": "mcpGateway.stopServer",
          "when": "view == mcpBackends && viewItem =~ /^(running|degraded)$/",
          "group": "1_lifecycle"
        },
        {
          "command": "mcpGateway.restartServer",
          "when": "view == mcpBackends && viewItem =~ /^(running|degraded|error|stopped)$/",
          "group": "1_lifecycle"
        },
        {
          "command": "mcpGateway.startServer",
          "when": "view == mcpBackends && viewItem == disabled",
          "group": "inline"
        },
        {
          "command": "mcpGateway.stopServer",
          "when": "view == mcpBackends && viewItem =~ /^(running|degraded)$/",
          "group": "inline"
        },
        {
          "command": "mcpGateway.restartServer",
          "when": "view == mcpBackends && viewItem =~ /^(running|degraded|error|stopped)$/",
          "group": "inline"
        },
        {
          "command": "mcpGateway.resetCircuit",
          "when": "view == mcpBackends && viewItem =~ /^(error|degraded)$/",
          "group": "1_lifecycle"
        },
        {
          "command": "mcpGateway.showLogs",
          "when": "view == mcpBackends && viewItem =~ /^(running|degraded|error|starting|restarting|stopped|disabled)$/",
          "group": "2_info"
        },
        {
          "command": "mcpGateway.showServerDetail",
          "when": "view == mcpBackends && viewItem =~ /^(running|degraded|error|starting|restarting|stopped|disabled)$/",
          "group": "2_info"
        },
        {
          "command": "mcpGateway.removeServer",
          "when": "view == mcpBackends && viewItem =~ /^(stopped|disabled|error|running|degraded)$/",
          "group": "3_danger"
        },
        {
          "command": "mcpGateway.restartSapVsp",
          "when": "view == mcpSapSystems && viewItem =~ /^(sap-(running|stopped|error|degraded|disabled|starting|restarting)|sap-group-|sap-vsp-)/",
          "group": "1_lifecycle"
        },
        {
          "command": "mcpGateway.restartSapGui",
          "when": "view == mcpSapSystems && viewItem =~ /^(sap-(running|stopped|error|degraded|disabled|starting|restarting)|sap-group-|sap-gui-)/",
          "group": "1_lifecycle"
        },
        {
          "command": "mcpGateway.showSapVspLogs",
          "when": "view == mcpSapSystems && viewItem =~ /^(sap-(running|stopped|error|degraded|disabled|starting|restarting)|sap-group-|sap-vsp-)/",
          "group": "2_info"
        },
        {
          "command": "mcpGateway.showSapGuiLogs",
          "when": "view == mcpSapSystems && viewItem =~ /^(sap-(running|stopped|error|degraded|disabled|starting|restarting)|sap-group-|sap-gui-)/",
          "group": "2_info"
        },
        {
          "command": "mcpGateway.showSapDetail",
          "when": "view == mcpSapSystems && viewItem =~ /^(sap-(running|stopped|error|degraded|disabled|starting|restarting)|sap-group-|sap-vsp-|sap-gui-)/",
          "group": "2_info"
        },
        {
          "command": "mcpGateway.showSapDetail",
          "when": "view == mcpSapSystems && viewItem == sap-imported",
          "group": "2_info"
        },
        {
          "command": "mcpGateway.addSapSystem",
          "when": "view == mcpSapSystems && viewItem == sap-imported",
          "group": "1_lifecycle"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "mcpBackends",
        "contents": "No MCP servers configured.\n[Add Server](command:mcpGateway.addServer)"
      },
      {
        "view": "mcpSapSystems",
        "contents": "No SAP systems detected.\nServers with vsp-* or sap-gui-* prefixes appear here automatically.\n[Add SAP System](command:mcpGateway.addSapSystem)",
        "when": "mcpGateway.sapSystemsEnabled"
      }
    ],
    "configuration": {
      "title": "MCP Gateway",
      "properties": {
        "mcpGateway.apiUrl": {
          "type": "string",
          "default": "http://localhost:8765",
          "description": "MCP Gateway REST API URL"
        },
        "mcpGateway.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start gateway daemon when VS Code opens"
        },
        "mcpGateway.daemonPath": {
          "type": "string",
          "default": "",
          "description": "Path to mcp-gateway executable (leave empty to use PATH)",
          "scope": "machine"
        },
        "mcpGateway.pollInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Status polling interval in milliseconds"
        },
        "mcpGateway.sapSystemsEnabled": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "description": "Show the SAP Systems view in the MCP Gateway activity bar. Off by default because SAP is a team-specific feature most users do not need. Flipping this setting requires running 'Developer: Reload Window' for the provider and status-bar lifecycle to catch up."
        },
        "mcpGateway.sapGroupBySid": {
          "type": "boolean",
          "default": false,
          "description": "Group SAP systems hierarchically (SID → VSP/GUI children). When off, each SAP system row shows composite status inline."
        },
        "mcpGateway.slashCommandsEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Auto-generate .claude/commands/<server>.md files when servers start or stop."
        },
        "mcpGateway.slashCommandsPath": {
          "type": "string",
          "default": "${workspaceFolder}/.claude/commands",
          "description": "Directory for auto-generated slash command files. Supports ${workspaceFolder} variable."
        },
        "mcpGateway.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "When true, every gateway REST call and response is logged to OutputChannel 'MCP Gateway' with URL, status, elapsed ms. Default off to keep the channel clean."
        },
        "mcpGateway.authTokenPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Bearer auth token file (default ~/.mcp-gateway/auth.token). MCP_GATEWAY_AUTH_TOKEN env var overrides this.",
          "scope": "machine"
        },
        "mcpGateway.keepassEnabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, the SAP Systems tree shows the union of daemon-detected SAP systems and systems whose credentials have been imported from KeePass. Imported entries appear as stopped until the daemon knows about them."
        },
        "mcpGateway.keepassPath": {
          "type": "string",
          "default": "",
          "description": "Path to the KDBX file for credential import (KeePass). Used by the 'Import KeePass Credentials' command.",
          "scope": "machine"
        },
        "mcpGateway.keepassGroup": {
          "type": "string",
          "default": "",
          "description": "Optional KeePass group to filter entries to (e.g. 'MCP/Servers'). Empty = all groups.",
          "scope": "machine"
        },
        "mcpGateway.marketplaceJsonPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional override path to a marketplace.json file (used by the Activate-for-Claude-Code button). When empty, mcp-ctl walks ancestors of the workspace folder to find marketplace.json. Set this when running VSCode from outside the mcp-gateway repo."
        },
        "mcpGateway.mcpCtlPath": {
          "type": "string",
          "default": "",
          "description": "Path to the mcp-ctl executable used by the KeePass import command (default: looked up on PATH).",
          "scope": "machine"
        },
        "mcpGateway.catalogPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional override path to a catalog directory containing servers.json and commands.json. When empty, the bundled catalog under the extension's installation directory is used."
        },
        "mcpGateway.claudeConfigSync.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Reflect gateway backends into ~/.claude.json::mcpServers so they appear in Claude Code's /mcp panel. Workaround for F-CC-V2-PLUGIN-MCPSERVERS-NOT-LOADED on Claude Code 2.1.123+. Disable when Anthropic restores the plugin loader to avoid duplicate /mcp entries."
        },
        "mcpGateway.claudeConfigSync.namespacePrefix": {
          "type": "string",
          "default": "mcp-gateway:",
          "description": "Prefix for managed mcpServers entries. Entries with this prefix are owned by the extension; all other keys are preserved verbatim. Change only if a name collision occurs."
        },
        "mcpGateway.claudeConfigSync.path": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Override path to Claude Code's user-scope config (default: ~/.claude.json)."
        },
        "mcpGateway.claudeConfigSync.aggregateEntryName": {
          "type": "string",
          "default": "mcp-gateway",
          "description": "Name of the managed entry that points at the aggregate gateway endpoint (/mcp without a backend suffix). Exposes gateway meta-tools (gateway.list_servers, gateway.list_tools, gateway.invoke). Empty string disables the aggregate entry."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build": "npm run compile",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "lint:catalog": "ajv validate --spec=draft7 --strict=true -c ajv-formats -s docs/catalog/schema.server.json -d docs/catalog/servers.json && ajv validate --spec=draft7 --strict=true -c ajv-formats -s docs/catalog/schema.command.json -d docs/catalog/commands.json && node scripts/check-catalog-refs.js",
    "lint:zombie-dom": "node scripts/check-zombie-dom.js",
    "pretest": "node scripts/check-zombie-dom.js",
    "test": "mocha --require ts-node/register --file 'src/test/setup.ts' 'src/test/**/*.test.ts'",
    "package": "vsce package --allow-missing-repository --out mcp-gateway-dashboard-latest.vsix",
    "deploy": "npm run compile && npm run package && node scripts/install-vsix.js mcp-gateway-dashboard-latest.vsix",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "ajv-cli": "^5.0.0",
    "mocha": "^10.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.3.0"
  }
}
